{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/typescript",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["cli/typescript", "server/typescript", "harness"]
}
