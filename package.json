{
  "name": "pathlens",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "A live local viewer for Markdown, HTML, code, and assets.",
  "bin": {
    "pathlens": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:server": "tsx src/cli/main.ts . --port 4317",
    "clean:dist": "node scripts/clean-dist.mjs",
    "build": "npm run clean:dist && tsc -p tsconfig.node.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "eval": "node --import tsx evals/run-evals.ts",
    "e2e": "PATHLENS_E2E=1 vitest run test/e2e",
    "verify:comment-ui": "npm run build && node scripts/verify-comment-ui-cdp.mjs",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "validate:scaffold": "node scripts/validate-scaffold.mjs",
    "check": "npm run validate:scaffold && npm run typecheck && npm run test && npm run eval && npm run e2e"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "marked": "latest",
    "mermaid": "^11.15.0",
    "react": "latest",
    "react-dom": "latest",
    "shiki": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
